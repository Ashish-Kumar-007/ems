// ============================================
// ENUMS
// ============================================

enum Role {
  SUPER_ADMIN
  HR_MANAGER
  EMPLOYEE
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  ASSIGN_MANAGER
  ASSIGN_ROLE
}

// ============================================
// DATASOURCE & GENERATOR
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH DOMAIN
// ============================================

/// User table: Handles authentication concerns only (SRP)
/// Relationship: 1:1 with Employee (FK in Employee side)
/// Relationship: 1:M with RefreshToken (FK in RefreshToken side)
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  role          Role           @default(EMPLOYEE)
  isActive      Boolean        @default(true)
  employee      Employee?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]     @relation("AuditPerformer")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// RefreshToken: Stores JWT refresh tokens
/// Relationship: M:1 with User (FK userId — "many" side holds FK)
model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// EMPLOYEE DOMAIN
// ============================================

/// Employee: Core business entity
/// Relationship: 1:1 with User (FK userId — UNIQUE enforces 1:1)
/// Relationship: M:1 with Department (FK departmentId — "many" side)
/// Relationship: Self-referencing 1:M for Manager↔Reportees (FK managerId)
model Employee {
  id              String         @id @default(uuid())
  employeeId      String         @unique
  userId          String         @unique
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  firstName       String
  lastName        String
  phone           String
  designation     String
  salary          Decimal        @db.Decimal(12, 2)
  joiningDate     DateTime
  status          EmployeeStatus @default(ACTIVE)
  profileImage    String?

  // Department: M:1 — FK on "many" side
  departmentId    String
  department      Department     @relation("DepartmentEmployees", fields: [departmentId], references: [id])

  // Org Hierarchy: Self-referencing 1:M
  managerId       String?
  manager         Employee?      @relation("ManagerReports", fields: [managerId], references: [id])
  reportees       Employee[]     @relation("ManagerReports")

  // Soft Delete
  isDeleted       Boolean        @default(false)
  deletedAt       DateTime?

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Back-relations
  auditLogs       AuditLog[]     @relation("AuditTarget")
  headOfDept      Department?    @relation("DepartmentHead")

  @@index([departmentId, status])
  @@index([status, isDeleted])
  @@index([firstName, lastName])
  @@index([joiningDate])
  @@index([managerId])
  @@index([isDeleted])
}

// ============================================
// ORGANIZATION DOMAIN
// ============================================

/// Department: Organizational unit
/// Relationship: 1:M with Employee (back-relation)
/// Relationship: 1:1 with Employee as head (FK headId)
model Department {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?
  headId      String?    @unique
  head        Employee?  @relation("DepartmentHead", fields: [headId], references: [id])
  employees   Employee[] @relation("DepartmentEmployees")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// ============================================
// AUDIT DOMAIN (Observer Pattern persistence)
// ============================================

/// AuditLog: Tracks all mutations for compliance & traceability
/// Relationship: M:1 with User (FK performedById)
/// Relationship: M:1 with Employee (FK targetEmployeeId)
model AuditLog {
  id               String      @id @default(uuid())
  action           AuditAction
  entityType       String
  entityId         String

  performedById    String
  performedBy      User        @relation("AuditPerformer", fields: [performedById], references: [id])

  targetEmployeeId String?
  targetEmployee   Employee?   @relation("AuditTarget", fields: [targetEmployeeId], references: [id])

  previousValues   Json?
  newValues        Json?
  ipAddress        String?
  userAgent        String?

  createdAt        DateTime    @default(now())

  @@index([performedById])
  @@index([targetEmployeeId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
